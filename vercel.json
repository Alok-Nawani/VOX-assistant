{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "apps/webapp/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "apps/webapp/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "apps/api/main.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
