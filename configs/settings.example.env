# API Keys (required for cloud services)
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here
ELEVENLABS_API_KEY=your_key_here

# Optional cloud services
SERPAPI_KEY=your_key_here
GOOGLE_CLOUD_KEY=your_key_here

# Local models
WHISPER_MODEL=small  # tiny, base, small, medium, large
WAKE_WORD_MODEL=hey_vox_v1
LLM_MODEL=phi-2  # phi-2, llama-7b, qwen-7b

# System settings
DEFAULT_TTS_VOICE=system  # system, pyttsx3, elevenlabs
DEFAULT_STT_ENGINE=whisper  # whisper, google
LOG_LEVEL=INFO
MEMORY_TTL_DAYS=30

# Security
SESSION_MODE=safe  # safe, balanced, handsfree
CONFIRMATION_TIMEOUT=30  # seconds
HANDSFREE_AUTO_LOCK=600  # 10 minutes
